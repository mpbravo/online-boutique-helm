          "default": "redis-cart:6379"
        },
        "inClusterRedis": {
          "title": "In-Cluster Redis",
          "description": "Deploy a Redis instance inside the cluster for the cart service",
          "type": "object",
          "properties": {
            "create": {
              "title": "Deploy In-Cluster Redis",
              "type": "boolean",
              "default": true
            },
