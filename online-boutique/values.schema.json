    "cartDatabase": {
      "title": "Cart Database",
      "description": "Backend database for the cart service",
      "type": "object",
      "properties": {
        "type": {
          "title": "Database Type",
          "description": "Type of database used by the cart service",
          "type": "string",
          "default": "redis",
