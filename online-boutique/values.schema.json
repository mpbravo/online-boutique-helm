    },
    "frontend": {
      "title": "Frontend",
      "description": "Web server that serves the Online Boutique UI and acts as an API gateway",
      "type": "object",
      "properties": {
        "create": {
          "title": "Deploy Frontend",
          "type": "boolean",
          "default": true
        },
        "name": {
          "title": "Service Name",
          "type": "string",
          "default": "frontend"
        },
        "externalService": {
          "title": "Expose as External Service",
          "description": "Create a LoadBalancer service to expose the frontend externally",
          "type": "boolean",
          "default": true
        },
        "cymbalBranding": {
          "title": "Enable Cymbal Branding",
          "description": "Replace the Online Boutique branding with Cymbal Shops branding",
          "type": "boolean",
          "default": false
        },
        "platform": {
          "title": "Platform",
          "description": "Target deployment platform. Defaults to 'local' unless auto-detected in GKE.",
          "type": "string",
          "default": "local",
          "enum": ["local", "gcp", "aws", "azure", "onprem", "alibaba"]
        },
        "singleSharedSession": {
          "title": "Single Shared Session",
          "description": "Use a single shared session across all frontend replicas",
          "type": "boolean",
          "default": false
        },
        "route": {
          "title": "OpenShift Route",
          "description": "Expose the frontend via an OpenShift Route (recommended for on-prem/local OpenShift instead of a LoadBalancer service). Disable externalService when using a Route.",
          "type": "object",
          "properties": {
            "create": {
              "title": "Create OpenShift Route",
              "description": "Create an OpenShift Route to expose the frontend externally. Set frontend.externalService to false when this is enabled.",
              "type": "boolean",
              "default": false
            },
            "host": {
              "title": "Hostname",
              "description": "Custom hostname for the Route (e.g. boutique.apps.example.com). Leave empty to let OpenShift auto-assign a hostname.",
              "type": "string",
              "default": ""
            },
            "tls": {
              "title": "TLS Configuration",
              "type": "object",
              "properties": {
                "enabled": {
                  "title": "Enable TLS",
                  "description": "Terminate TLS at the OpenShift router (HTTPS access).",
                  "type": "boolean",
                  "default": false
                },
                "termination": {
                  "title": "TLS Termination",
                  "description": "edge: TLS terminated at the router, plain HTTP to the pod. reencrypt: re-encrypted to the pod.",
                  "type": "string",
                  "default": "edge",
                  "enum": ["edge", "reencrypt"]
                },
                "insecureEdgeTerminationPolicy": {
                  "title": "HTTP Traffic Policy",
                  "description": "How to handle plain HTTP traffic when TLS is enabled.",
                  "type": "string",
                  "default": "Redirect",
                  "enum": ["Redirect", "Allow", "None"]
                }
              }
            }
          }
        },
        "virtualService": {
          "title": "Istio VirtualService",
          "description": "Create an Istio VirtualService for the frontend (requires Istio)",
          "type": "object",
          "properties": {
            "create": {
              "title": "Create VirtualService",
              "type": "boolean",
              "default": false
            },
            "hosts": {
              "title": "Hosts",
              "description": "List of hosts for the VirtualService",
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": ["*"]
            },
            "gateway": {
              "title": "Istio Gateway",
              "type": "object",
              "properties": {
                "name": {
                  "title": "Gateway Name",
                  "type": "string",
                  "default": "asm-ingressgateway"
                },
                "namespace": {
                  "title": "Gateway Namespace",
                  "type": "string",
                  "default": "asm-ingress"
                },
                "labelKey": {
                  "title": "Gateway Label Key",
                  "type": "string",
                  "default": "asm"
                },
                "labelValue": {
                  "title": "Gateway Label Value",
                  "type": "string",
                  "default": "ingressgateway"
                }
              }
            }
          }
        },
        "resources": {
          "title": "Resource Requests & Limits",
          "type": "object",
          "properties": {
            "requests": {
              "title": "Requests",
              "type": "object",
              "properties": {
                "cpu": {
                  "title": "CPU Request",
                  "type": "string",
                  "default": "100m"
                },
                "memory": {
                  "title": "Memory Request",
                  "type": "string",
                  "default": "64Mi"
                }
              }
            },
            "limits": {
              "title": "Limits",
              "type": "object",
