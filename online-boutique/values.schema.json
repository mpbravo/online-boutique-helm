{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Online Boutique",
  "description": "Configuration for the Online Boutique microservices demo application",
  "type": "object",
  "properties": {
    "images": {
      "title": "Container Images",
      "description": "Container image settings shared across all services",
      "type": "object",
      "properties": {
        "repository": {
          "title": "Image Repository",
          "description": "Base container image repository for all microservices",
          "type": "string",
          "default": "us-central1-docker.pkg.dev/google-samples/microservices-demo"
        },
        "tag": {
          "title": "Image Tag",
          "description": "Container image tag. Defaults to the chart appVersion when left empty.",
          "type": "string",
          "default": ""
        }
      }
    },
    "serviceAccounts": {
      "title": "Service Accounts",
      "description": "Kubernetes ServiceAccount configuration",
      "type": "object",
      "properties": {
        "create": {
          "title": "Create Service Accounts",
          "description": "Specifies whether a ServiceAccount should be created for each service",
          "type": "boolean",
          "default": true
        },
        "annotationsOnlyForCartservice": {
          "title": "Annotations Only for Cart Service",
          "description": "Apply the service account annotations only to cartservice (useful for Workload Identity least-privilege access to an external database)",
          "type": "boolean",
          "default": false
        }
      }
    },
    "networkPolicies": {
      "title": "Network Policies",
      "description": "Kubernetes NetworkPolicy configuration",
      "type": "object",
      "properties": {
        "create": {
          "title": "Create Network Policies",
          "description": "Create one fine-grained NetworkPolicy per service to restrict inter-service traffic",
          "type": "boolean",
          "default": false
        }
      }
    },
    "sidecars": {
      "title": "Istio Sidecars",
      "description": "Istio Sidecar resource configuration",
      "type": "object",
      "properties": {
        "create": {
          "title": "Create Sidecar Resources",
          "description": "Create one fine-grained Istio Sidecar resource per service",
          "type": "boolean",
          "default": false
        }
      }
    },
    "authorizationPolicies": {
      "title": "Authorization Policies",
      "description": "Istio AuthorizationPolicy configuration",
      "type": "object",
      "properties": {
        "create": {
          "title": "Create Authorization Policies",
          "description": "Create one fine-grained Istio AuthorizationPolicy per service",
          "type": "boolean",
          "default": false
        }
      }
    },
    "opentelemetryCollector": {
      "title": "OpenTelemetry Collector",
      "description": "Deploy and configure an OpenTelemetry Collector for distributed tracing",
      "type": "object",
      "properties": {
        "create": {
          "title": "Deploy OpenTelemetry Collector",
          "description": "Deploy an OpenTelemetry Collector alongside the application",
          "type": "boolean",
          "default": false
        },
        "name": {
          "title": "Collector Name",
          "description": "Name for the OpenTelemetry Collector deployment",
          "type": "string",
          "default": "opentelemetrycollector"
        },
        "projectId": {
          "title": "GCP Project ID",
          "description": "Google Cloud project ID used by the collector. When set to PROJECT_ID, an initContainer auto-retrieves it from the GCP metadata server.",
          "type": "string",
          "default": "PROJECT_ID"
        }
      }
    },
    "googleCloudOperations": {
      "title": "Google Cloud Operations",
      "description": "Enable Google Cloud Observability integrations (Cloud Profiler, Cloud Trace, Cloud Monitoring)",
      "type": "object",
      "properties": {
        "profiler": {
          "title": "Enable Cloud Profiler",
          "description": "Enable Google Cloud Profiler for continuous CPU and heap profiling",
          "type": "boolean",
          "default": false
        },
        "tracing": {
          "title": "Enable Cloud Trace",
          "description": "Enable Google Cloud Trace for distributed tracing",
          "type": "boolean",
          "default": false
        },
        "metrics": {
          "title": "Enable Cloud Monitoring",
          "description": "Enable Google Cloud Monitoring for metrics collection",
          "type": "boolean",
          "default": false
        }
      }
    },
    "seccompProfile": {
      "title": "Seccomp Profile",
      "description": "Linux seccomp syscall filtering for all containers",
      "type": "object",
      "properties": {
        "enable": {
          "title": "Enable Seccomp Profile",
          "description": "Apply a seccomp profile to all containers",
          "type": "boolean",
          "default": false
        },
        "type": {
          "title": "Seccomp Profile Type",
          "description": "Type of seccomp profile to apply",
          "type": "string",
          "default": "RuntimeDefault",
          "enum": ["RuntimeDefault", "Localhost", "Unconfined"]
        }
      }
    },
    "securityContext": {
      "title": "Security Context",
      "description": "Pod and container security context settings",
      "type": "object",
      "properties": {
        "enable": {
          "title": "Enable Security Context",
          "description": "Apply security contexts (non-root user, read-only filesystem, dropped capabilities) to all containers",
          "type": "boolean",
          "default": true
        },
        "openshift": {
          "title": "OpenShift Mode",
          "description": "Set to true when deploying on OpenShift. Omits runAsUser, runAsGroup and fsGroup so OpenShift can assign them from the namespace UID/GID range, which is required by the restricted and restricted-v2 SCCs.",
          "type": "boolean",
          "default": true
        }
      }
    },
    "adService": {
      "title": "Ad Service",
      "description": "Serves text ads based on context keywords",
      "type": "object",
      "properties": {
        "create": {
          "title": "Deploy Ad Service",
          "type": "boolean",
          "default": true
        },
        "name": {
          "title": "Service Name",
          "type": "string",
          "default": "adservice"
        },
        "resources": {
          "title": "Resource Requests & Limits",
          "type": "object",
          "properties": {
            "requests": {
              "title": "Requests",
              "type": "object",
              "properties": {
                "cpu": {
                  "title": "CPU Request",
                  "description": "Minimum CPU (e.g. 200m)",
                  "type": "string",
                  "default": "200m"
                },
                "memory": {
                  "title": "Memory Request",
                  "description": "Minimum memory (e.g. 180Mi)",
                  "type": "string",
                  "default": "180Mi"
                }
              }
            },
            "limits": {
              "title": "Limits",
              "type": "object",
              "properties": {
                "cpu": {
                  "title": "CPU Limit",
                  "description": "Maximum CPU (e.g. 300m)",
                  "type": "string",
                  "default": "300m"
                },
                "memory": {
                  "title": "Memory Limit",
                  "description": "Maximum memory (e.g. 300Mi)",
                  "type": "string",
                  "default": "300Mi"
                }
              }
            }
          }
        }
      }
    },
    "cartService": {
      "title": "Cart Service",
      "description": "Stores items in the user's shopping cart in Redis",
